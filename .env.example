# Copy to .env.local for local dev (not committed).
# Vite public vars (required for dev/build)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: public catalog realtime (see src/lib/useSupabase.js)
# VITE_ENABLE_PUBLIC_CATALOG_REALTIME=1

# Dev-only — never enable in production builds
# VITE_USE_PREVIEW_RPC=1
# VITE_ALLOW_APPROVE_LINK_FALLBACK=1

# ---------------------------------------------------------------------------
# RLS / RPC probes (scripts/security/rls-rpc-probe.mjs) — use staging only
# ---------------------------------------------------------------------------
# PROBE_SUPABASE_URL=https://your-staging.supabase.co
# PROBE_SUPABASE_ANON_KEY=same as anon key for that project
# Or rely on VITE_* above if you point them at staging.

# Access token from Supabase Auth (short-lived). Use a disposable test user.
# PROBE_JWT_USER_A=eyJhbGciOiJIUzI1NiIs...
# PROBE_JWT_USER_B=

# Another client's UUID (not linked to User A) — for cross-tenant deny checks.
# PROBE_FOREIGN_CLIENT_ID=00000000-0000-0000-0000-000000000000

# ---------------------------------------------------------------------------
# Table probes (scripts/security/rls-table-probe.mjs) — optional env
# Supply real ids owned by User A to run the C1/H2 regression probes. If
# unset, those rows are skipped with a clear [skip] message.
# ---------------------------------------------------------------------------
# PROBE_OWN_PAYMENT_ID=00000000-0000-0000-0000-000000000000
# PROBE_OWN_PLAN_ID=00000000-0000-0000-0000-000000000000

# ---------------------------------------------------------------------------
# Race probe (scripts/security/race-payout-probe.mjs) — H1 verification
# DESTRUCTIVE: creates real commission_payout_requests rows. Staging only.
# Requires User A to have payable commission events.
# ---------------------------------------------------------------------------
# PROBE_PAYOUT_AMOUNT=1
# PROBE_PAYOUT_PARALLELISM=10
